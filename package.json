{
  "name": "praxis-study-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mock": "VITE_PREVIEW_HOME_DASHBOARD=true vite --open '/?mock=home-dashboard'",
    "dev:netlify": "netlify dev",
    "build": "npm run scan:types && vite build",
    "preview": "vite preview",
    "generate:practice": "npx tsx scripts/generate-practice.ts",
    "test": "vitest run",
    "test:runtime": "npx tsx tests/adaptive-coaching.test.ts && npx tsx tests/code-health.test.ts",
    "verify:health": "npm run test:runtime && npm run diagnostics && npm run build",
    "scan:types": "tsc -p tsconfig.json --noEmit",
    "scan:knip": "knip --config knip.json --include files,exports,dependencies --no-config-hints",
    "scan:cycles": "dpdm 'App.tsx' 'src/main.tsx' 'api/**/*.ts' 'scripts/**/*.{ts,cjs}' 'src/scripts/**/*.ts' 'tests/**/*.ts' --tsconfig tsconfig.json --tree false --warning false -T",
    "diagnostics": "npx tsx src/scripts/run-all-diagnostics.ts",
    "audit:distractors": "npx tsx scripts/audit-distractor-quality.ts",
    "test:banned-terms": "npx tsx scripts/banned-terms-check.ts",
    "audit:bank": "npx tsx scripts/audit-question-bank.ts",
    "audit:answers": "npx tsx scripts/audit-answer-distribution.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.1",
    "csv-parse": "^6.1.0",
    "docx": "^9.6.1",
    "file-saver": "^2.0.5",
    "lucide-react": "^0.263.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.0.3",
    "autoprefixer": "^10.4.14",
    "dpdm": "^4.0.1",
    "knip": "^5.86.0",
    "pg": "^8.20.0",
    "postcss": "^8.4.27",
    "tailwindcss": "^3.3.3",
    "typescript": "^5.0.2",
    "vite": "^6.4.1",
    "vitest": "^4.1.2"
  }
}
