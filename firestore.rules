rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email == 'clebronrivera@icloud.com';
    }

    // Users can only read/write their own profile data
    match /users/{userId} {
      // Allow read/write only if authenticated and accessing own data
      allow read, write: if (signedIn() && request.auth.uid == userId) || isAdmin();
      
      // Allow users to create their own profile document
      allow create: if (signedIn() && request.auth.uid == userId) || isAdmin();
      
      // Response logs subcollection - users can only access their own responses
      match /responses/{responseId} {
        allow read, write: if (signedIn() && request.auth.uid == userId) || isAdmin();
        allow create: if (signedIn() && request.auth.uid == userId) || isAdmin();
      }
    }

    match /responses/{userId}/screener/{responseId} {
      allow read, write: if (signedIn() && request.auth.uid == userId) || isAdmin();
      allow create: if (signedIn() && request.auth.uid == userId) || isAdmin();
    }

    match /userProgress/{userId}/globalScores/{docId} {
      allow read, write: if (signedIn() && request.auth.uid == userId) || isAdmin();
      allow create: if (signedIn() && request.auth.uid == userId) || isAdmin();
    }

    match /studyPlans/{userId}/plans/{docId} {
      allow read, write: if (signedIn() && request.auth.uid == userId) || isAdmin();
      allow create: if (signedIn() && request.auth.uid == userId) || isAdmin();
    }

    match /questionReports/{reportId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /betaFeedback/{feedbackId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }
    
    // Questions and Skills - allow read to all, write only to authenticated users
    match /questions/{questionId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /skills/{skillId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
